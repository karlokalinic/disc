# Keep the repository source-first. The extracted commercial assets remain local.
Assets/**

# Let Git descend into Assets, but only track source/config and recreated scenes.
!Assets/
!Assets/**/
!Assets/**/*.cs
!Assets/**/*.cs.meta
!Assets/**/*.asmdef
!Assets/**/*.asmdef.meta
!Assets/**/*.asmref
!Assets/**/*.asmref.meta
!Assets/_IntroReal/**/*.controller
!Assets/_IntroReal/**/*.controller.meta
!Assets/_IntroReal/**/*.unity
!Assets/_IntroReal/**/*.unity.meta
!Assets/csc.rsp
!Assets/csc.rsp.meta

