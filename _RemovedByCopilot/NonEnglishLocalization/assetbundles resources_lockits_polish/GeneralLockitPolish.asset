      Languages_Touch: []
    - Term: Items/postcard_la_delta/Description
      TermType: 0
      Languages:
      - Słońce sprawiło, że kartka ta wypłowiała niemal do barw sepii. Ruch uliczny w centrum, wyżej znikające w beżowej, dziennej mgle – oparach z delty, na której zbudowano dzielnicę – duchy drapaczy chmur. Pocztówka jest opłacona z góry.
      Flags: 00
      Languages_Touch: []
