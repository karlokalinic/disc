      - Atakowanie obiektów fizycznych leczy obrażenia
      Flags: 00
      Languages_Touch: []
    - Term: Thoughts/the_waste_land_of_reality/Completion/+1 Psyche
      TermType: 0
      Languages:
      - Powrót jaźni
      Flags: 00
      Languages_Touch: []
    - Term: Thoughts/the_waste_land_of_reality/Completion/-1 Inland Empire
      TermType: 0
