      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x0100002B000081C7/Description
      TermType: 0
      Languages:
      - Spraw jakoś, żeby ten rozdęty trup przestał być tam na górze. Zestrzel go albo poproś o pomoc. Zrób coś. Jesteś policjantem.
      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x0100002B000081C7/Title
      TermType: 0
      Languages:
