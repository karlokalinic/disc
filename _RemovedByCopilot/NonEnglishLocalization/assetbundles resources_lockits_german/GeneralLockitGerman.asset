      TermType: 0
      Languages:
      - Höre dich nach einem Kühlschrank um.
      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x01000095000000B0/subtask_title_02
      TermType: 0
      Languages:
      - Sieh dir den Kühlschrank im Gewerbegebäude gegenüber vom Whirling an.
      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x01000095000000B0/subtask_title_03
      TermType: 0
      Languages:
      - Versorge den Eisbärkühlschrank mit Strom.
      Flags: 00
      Languages_Touch: []
