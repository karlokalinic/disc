      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x0100003100006E87/Description
      TermType: 0
      Languages:
      - Sylvie hat dich gebeten, mit Garte zu sprechen und ihm auszurichten, dass es ihr leidtut. Gehe zum Cafeteriamanager und gib die Neuigkeit weiter; vielleicht bringt dich das irgendwie weiter?
      Flags: 00
      Languages_Touch: []
