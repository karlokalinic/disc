      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x01000097000000AF/subtask_title_04
      TermType: 0
      Languages:
      - Suche Wohnung 28 nach 21:00 Uhr auf, um nachzusehen, ob jemand zu Hause ist.
      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x01000097000000C5/Description
      TermType: 0
      Languages:
      - Warum hat er das getan? Warum???
      Flags: 00
      Languages_Touch: []
