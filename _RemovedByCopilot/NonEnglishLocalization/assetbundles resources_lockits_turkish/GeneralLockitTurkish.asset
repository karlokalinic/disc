      TermType: 0
      Languages:
      - PLAZA / COUPRIS KINEEMA
      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x0100004C0000074E/Description
      TermType: 0
      Languages:
      - "Your first contact with the colleagues back in station 41.\n\n* Report your badge missing\n* Report your gun missing\n* Get laughed at\n* Beg your station for additional funds\n* Get a panic attack\n* Get an aweseome Firewalker persona\n* Get the \"Find your badge\" quest\n* Get the \"Find your gun\" quest.\n* Get the \"Check the local pawnshops\" quest."
      Flags: 00
      Languages_Touch: []
