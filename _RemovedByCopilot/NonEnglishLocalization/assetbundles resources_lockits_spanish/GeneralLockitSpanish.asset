      Flags: 00
      Languages_Touch: []
    - Term: Conversation/0x0100007500000A9E/subtask_title_02
      TermType: 0
      Languages:
      - Contacta con la comisaría de Kim y cédeles el caso.
      Flags: 00
      Languages_Touch: []
