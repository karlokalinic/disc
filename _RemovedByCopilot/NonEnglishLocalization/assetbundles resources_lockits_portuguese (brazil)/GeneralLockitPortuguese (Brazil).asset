      Languages_Touch: []
    - Term: Archetypes/ARCHETYPE_DESC_PHYSICAL
      TermType: 0
      Languages:
      - Extremamente físico. Interage com o mundo através do próprio corpo. Faz as coisas acontecerem, mas é tapado como uma rocha.
      Flags: 00
      Languages_Touch: []
    - Term: Archetypes/ARCHETYPE_DESC_SENSITIVE
